{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MDA_UI_MODE": "rest"
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Bash(./mvnw:*)",
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(ng:*)",
      "Bash(./scripts/count-tests.sh)",
      "Bash(./scripts/*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(git worktree:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(glab issue:*)",
      "Bash(glab mr:*)",
      "Bash(glab api:*)",
      "Bash(ls:*)",
      "Bash(find specs:*)",
      "Bash(find src:*)",
      "Bash(find docs:*)",
      "Bash(find plan:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(rm:-rf .trees/*)",
      "Bash(rm:-rf target/*)",
      "Bash(rm:-rf src/main/webui/node_modules)",
      "Bash(rm:src/main/webui/dist/*)",
      "Bash(curl:*)",
      "Bash(pkill:-f quarkus)",
      "Bash(jq:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(rm:-rf /)",
      "Bash(rm:-rf ~)",
      "Bash(rm:-rf src)",
      "Bash(rm:-rf src/*)",
      "Bash(rm:-rf specs)",
      "Bash(rm:-rf specs/*)",
      "Bash(rm:-rf plan)",
      "Bash(rm:-rf plan/*)",
      "Bash(rm:-rf .claude)",
      "Bash(rm:-rf .claude/*)",
      "Bash(mvn *-DskipTests*)",
      "Bash(./mvnw *-DskipTests*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/drift-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/bash-safeguard.sh"
          }
        ]
      }
    ]
  }
}
