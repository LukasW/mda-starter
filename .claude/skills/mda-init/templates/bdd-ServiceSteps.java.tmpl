    }

    @Dann("^wird die Anfrage mit HTTP (\\d+) und Code \"([^\"]+)\" abgewiesen$")
    public void wirdMitCodeAbgewiesen(int status, String code) {
        assertEquals(status, lastResponse.statusCode());
        assertEquals(code, lastResponse.jsonPath().getString("code"));
    }
}
