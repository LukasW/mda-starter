# Template: src/main/resources/application.properties
# Platzhalter: {{default_schema}} (z. B. "app")
quarkus.http.port=8080

# Datasource – Dev/Test: H2; Prod: PostgreSQL (Override via application-prod.properties)
quarkus.datasource.db-kind=h2
quarkus.datasource.jdbc.url=jdbc:h2:mem:mda;DB_CLOSE_DELAY=-1;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE

# Hibernate
quarkus.hibernate-orm.database.generation=validate
quarkus.hibernate-orm.database.default-schema={{default_schema}}

# Flyway
quarkus.flyway.migrate-at-start=true
quarkus.flyway.baseline-on-migrate=true
quarkus.flyway.default-schema={{default_schema}}

# API / Observability
quarkus.smallrye-openapi.path=/openapi
quarkus.smallrye-health.root-path=/q/health

# Test profile
%test.quarkus.datasource.jdbc.url=jdbc:h2:mem:mda-test;DB_CLOSE_DELAY=-1;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE
%test.quarkus.flyway.clean-at-start=true
%test.quarkus.flyway.clean-disabled=false
