@startuml
skinparam defaultFontName "Inter"
skinparam classBackgroundColor #F5F7FA
skinparam classBorderColor #2B4C7E
hide circle

class Mandant {
  +mandantId: UUID
  +name: String
  +retentionProfil: RetentionProfil
}

class Vertrag <<Aggregate Root>> {
  +vertragId: UUID
  +mandantId: UUID
  +titel: String
  +vertragsart: Vertragsart
  +partnerId: UUID
  +status: VertragStatus
  +startDatum: LocalDate
  +endDatum: LocalDate
  +kuendigungsfristTage: Integer
  +vertragsverantwortlicherUserId: UUID
  +erstelltAm: Instant
  +erstelltVon: UUID
}

class DokumentVersion {
  +versionId: UUID
  +vertragId: UUID
  +versionNummer: Integer
  +blobReferenz: String
  +pruefsummeSha256: String
  +dateiname: String
  +mimeType: String
  +groesseBytes: Long
  +aenderungskommentar: String
  +hochgeladenAm: Instant
  +hochgeladenVon: UUID
}

class Freigabe <<Aggregate Root>> {
  +freigabeId: UUID
  +vertragId: UUID
  +versionId: UUID
  +reviewerUserId: UUID
  +entscheidung: Entscheidung
  +begruendung: String
  +entschiedenAm: Instant
}

class Frist <<Aggregate Root>> {
  +fristId: UUID
  +vertragId: UUID
  +art: FristArt
  +faelligkeitsDatum: LocalDate
  +vorlaufTage: Integer
  +erinnerungsDatum: LocalDate
  +status: FristStatus
}

class Erinnerung {
  +erinnerungId: UUID
  +fristId: UUID
  +ausgeloestAm: Instant
  +empfaengerUserId: UUID
  +gesichtetAm: Instant
  +folgeAktion: FolgeAktion
}

class Partner {
  +partnerId: UUID
  +name: String
  +uidNummer: String
  +adresse: String
}

class AuditEvent {
  +eventId: UUID
  +vertragId: UUID
  +eventTyp: String
  +aktorUserId: UUID
  +zeitpunkt: Instant
  +payload: JSONB
  +korrelationsId: UUID
}

enum VertragStatus {
  ENTWURF
  IN_PRUEFUNG
  UEBERARBEITUNG
  FREIGEGEBEN
  AKTIV
  IN_KUENDIGUNG
  BEENDET
  ABGELAUFEN
  ARCHIVIERT
}

enum FristArt {
  KUENDIGUNG
  VERLAENGERUNG
  ABLAUF
  INDIVIDUELL
}

enum FristStatus {
  OFFEN
  ERINNERT
  ERLEDIGT
  ESKALIERT
}

enum Entscheidung {
  GENEHMIGT
  ABGELEHNT
}

enum FolgeAktion {
  KUENDIGEN
  VERLAENGERN
  KEINE_AKTION
}

enum Vertragsart {
  DIENSTLEISTUNG
  MIETE
  LIZENZ
  RUECKVERSICHERUNG
  ARBEIT
}

Mandant "1" -- "*" Vertrag
Vertrag "1" *-- "1..*" DokumentVersion
Vertrag "1" *-- "*" Freigabe
Vertrag "1" *-- "*" Frist
Vertrag "1" -- "1" Partner
Frist "1" *-- "*" Erinnerung
Vertrag "1" -- "*" AuditEvent

@enduml
