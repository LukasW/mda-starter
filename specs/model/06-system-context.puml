@startuml
!define RECTANGLE class
skinparam defaultFontName "Inter"
skinparam componentBackgroundColor #F5F7FA
skinparam componentBorderColor #2B4C7E

actor "Fachbereich" as User
actor "Rechtsabteilung" as Legal
actor "Compliance" as Compliance

component "CLM Frontend\n(Angular)" as FE
component "Contract Service\n(Quarkus)" as CS
component "Approval Service\n(Quarkus)" as AS
component "Obligation Service\n(Quarkus)" as OS
component "Audit Service\n(Quarkus)" as AUS
component "Notification Service\n(Quarkus)" as NS

database "PostgreSQL\n(Contract DB)" as PGC
database "PostgreSQL\n(Approval DB)" as PGA
database "PostgreSQL\n(Obligation DB)" as PGO
database "PostgreSQL\n(Audit DB, append-only)" as PGAUD
database "Blob Storage" as BLOB
queue "Kafka" as KAFKA

component "Keycloak" as KC
component "SMTP Gateway" as SMTP
component "OpenSearch" as SEARCH

User --> FE
Legal --> FE
Compliance --> FE
FE --> CS
FE --> AS
FE --> OS
FE --> KC

CS --> PGC
CS --> BLOB
CS --> KAFKA
AS --> PGA
AS --> KAFKA
OS --> PGO
OS --> KAFKA
AUS --> PGAUD
AUS <-- KAFKA
NS <-- KAFKA
NS --> SMTP
SEARCH <-- KAFKA
FE --> SEARCH : Suche

@enduml
